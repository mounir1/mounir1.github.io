rules_version = '2';
// ─── Firestore Security Rules ────────────────────────────────────────────────
// Portfolio CMS – mounir1.github.io
// Rules:
//   • Public: read-only for projects, experiences, skills, testimonials
//   • Admin:  full write access (authenticated + email-verified)
//   • Analytics: write-only for authenticated sessions + unauthenticated
//     (allows anonymous event tracking)
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    // Returns true when the caller is signed in with a verified email.
    function isAdmin() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    // Verify the incoming document has the required timestamp fields.
    function hasTimestamps() {
      return request.resource.data.keys().hasAll(['createdAt', 'updatedAt']);
    }

    // Ensure priority is within 0–100.
    function validPriority() {
      return request.resource.data.priority is int
          && request.resource.data.priority >= 0
          && request.resource.data.priority <= 100;
    }

    // ── Projects ──────────────────────────────────────────────────────────────
    match /projects/{projectId} {
      // Anyone can read non-disabled projects
      allow read: if resource == null || resource.data.disabled == false;

      // Admins can read all (including disabled)
      allow read: if isAdmin();

      // Admins can create/update with valid data
      allow create: if isAdmin()
          && hasTimestamps()
          && validPriority()
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 3;

      allow update: if isAdmin()
          && hasTimestamps()
          && validPriority()
          // Prevent downgrading version
          && request.resource.data.version >= resource.data.version;

      allow delete: if isAdmin();
    }

    // ── Experiences ───────────────────────────────────────────────────────────
    match /experiences/{experienceId} {
      allow read: if resource == null || resource.data.disabled == false;
      allow read: if isAdmin();

      allow create: if isAdmin()
          && hasTimestamps()
          && validPriority()
          && request.resource.data.title is string
          && request.resource.data.company is string;

      allow update: if isAdmin() && hasTimestamps() && validPriority();
      allow delete: if isAdmin();
    }

    // ── Skills ────────────────────────────────────────────────────────────────
    match /skills/{skillId} {
      allow read: if resource == null || resource.data.disabled == false;
      allow read: if isAdmin();

      allow create: if isAdmin()
          && hasTimestamps()
          && validPriority()
          && request.resource.data.name is string
          && request.resource.data.level is int
          && request.resource.data.level >= 1
          && request.resource.data.level <= 100;

      allow update: if isAdmin() && hasTimestamps() && validPriority();
      allow delete: if isAdmin();
    }

    // ── Testimonials ──────────────────────────────────────────────────────────
    match /testimonials/{testimonialId} {
      allow read: if resource == null || resource.data.disabled == false;
      allow read: if isAdmin();

      allow create: if isAdmin()
          && hasTimestamps()
          && validPriority()
          && request.resource.data.clientName is string
          && request.resource.data.content is string
          && request.resource.data.content.size() >= 20;

      allow update: if isAdmin() && hasTimestamps();
      allow delete: if isAdmin();
    }

    // ── Blog Posts (future) ───────────────────────────────────────────────────
    match /blog_posts/{postId} {
      allow read: if resource == null || resource.data.published == true;
      allow read: if isAdmin();
      allow write: if isAdmin() && hasTimestamps();
    }

    // ── Analytics ─────────────────────────────────────────────────────────────
    // Write-only for everyone (anonymous event tracking).
    // Admins can read analytics for the dashboard.
    match /analytics/{eventId} {
      allow create: if request.resource.data.keys().hasAll(['type', 'timestamp'])
          && request.resource.data.timestamp is number;

      allow read: if isAdmin();
      // Nobody can update or delete analytics events (immutable log)
      allow update, delete: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Users can only read/write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ── Default: deny everything not explicitly matched ────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
